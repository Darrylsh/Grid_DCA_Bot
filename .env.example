# Binance API Keys (required for LIVE trading mode)
# Permissions needed: Spot Trading, Read
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Gemini API Key (for AI features, optional)
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL Database Configuration
DB_USER=trading_bot
DB_PASS=your_database_password_here
DB_NAME=Gridbot
DB_HOST=your_database_host_here
DB_PORT=5432

# Backend Server Configuration
PORT=3030
HEADLESS_SERVER_URL=http://your_server_ip_here:3030
# CORS Origin for Socket.io (optional, comma-separated list, default: *)
CORS_ORIGIN=*

# Telegram Bot Notifications (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Binance Testnet (for development/testing, optional)
TESTNET_BINANCE_API_KEY=your_testnet_api_key_here
TESTNET_API_SECRET=your_testnet_api_secret_here

# GitHub Token for Auto-Updater Publishing
# Required for: npm run publish:win, npm run publish:mac, npm run publish:linux
# Permissions needed: "repo" scope (for publishing releases)
# Note: Only needed when publishing new releases, not for regular use
GITHUB_TOKEN=your_github_token_here
GH_TOKEN=your_github_token_here  # electron-builder looks for GH_TOKEN specifically